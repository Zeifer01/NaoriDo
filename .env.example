# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=restai
POSTGRES_PASSWORD=change-me-in-production

# ── API Server ────────────────────────────────────────────────────────
API_PORT=3001
# Public base URL for locally stored uploads (defaults to http://localhost:API_PORT)
# API_PUBLIC_URL=http://localhost:3001
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── Database (composed automatically in docker-compose) ───────────────
# Only needed when running outside Docker:
# DATABASE_URL=postgresql://restai:change-me-in-production@localhost:5432/restai

# ── Redis (hardcoded in docker-compose as redis://redis:6379) ─────────
# Only needed when running outside Docker:
# REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 Storage ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=restai
R2_PUBLIC_URL=

# ── Web App (build-time — set as Build Variable in Coolify) ──────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── WhatsApp (Evolution API v2 — opcional) ───────────────────────────
# Local (mesma máquina): http://localhost:8085
# Com Cloudflare Tunnel: use a URL *.trycloudflare.com (bun run tunnel:up)
WHATSAPP_ENABLED=true
WHATSAPP_API_URL=http://localhost:8085
WHATSAPP_API_KEY=restai-evolution-dev-key
WHATSAPP_INSTANCE=restai
EVOLUTION_PORT=8085

# ── Cloudflare Tunnel (profile: tunnel) ───────────────────────────────
# Deixe vazio para Quick Tunnel (URL temporária, sem conta Cloudflare).
# Para URL fixa: crie um túnel em https://one.dash.cloudflare.com → Networks → Tunnels
# e aponte o hostname para http://evolution-api:8080
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Port mapping (optional) ──────────────────────────────────────────
WEB_PORT=3000
