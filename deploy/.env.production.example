# ─────────────────────────────────────────────────────────────────────────────
#  Naori — .env de produção (template)
# ─────────────────────────────────────────────────────────────────────────────
#  Copie para `.env` na raiz do projeto e PREENCHA todos os valores marcados
#  com `change-me`. Use senhas/secrets de pelo menos 32 caracteres aleatórios.
#
#  Gere secrets fortes com:
#       openssl rand -base64 48
#  ou:
#       openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=naori
POSTGRES_PASSWORD=change-me-com-openssl-rand-base64-48

# ── API (backend) ───────────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-com-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-com-openssl-rand-base64-48-DIFERENTE-do-primeiro
LOG_LEVEL=info

# CORS: domínios autorizados a chamar a API. Em produção é o domínio do frontend.
CORS_ORIGINS=https://naorido.com.br,https://www.naorido.com.br

# URL pública da API (sem barra final)
APP_URL=https://naorido.com.br
API_PUBLIC_URL=https://api.naorido.com.br

# ── Cloudflare R2 (upload de imagens) ───────────────────────────────────────
# Crie em: https://dash.cloudflare.com → R2 → criar bucket "naori" → API Tokens
R2_ACCOUNT_ID=change-me
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me
R2_BUCKET_NAME=naori
R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev

# ── Web App (build-time variables) ──────────────────────────────────────────
# Estas variáveis são "queimadas" no bundle do Next.js no momento do `docker build`.
# Se mudar uma delas, precisa rebuilder o container `web`.
NEXT_PUBLIC_API_URL=https://api.naorido.com.br
NEXT_PUBLIC_WS_URL=wss://api.naorido.com.br
NEXT_PUBLIC_APP_URL=https://naorido.com.br

# ── WhatsApp (Evolution API) ────────────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_API_URL=http://evolution-api:8080
WHATSAPP_API_KEY=change-me-com-openssl-rand-hex-32
WHATSAPP_INSTANCE=naori
EVOLUTION_PORT=8085

# Versão do WhatsApp Web que o Baileys vai emular (atualize conforme o WA web).
CONFIG_SESSION_PHONE_VERSION=2.3000.1028355510
WEB_VERSION=2.3000.1028355510

# ── Cloudflare Tunnel (opcional, para expor Evolution API externamente) ─────
# Em produção NÃO precisa expor o Evolution. Deixe vazio.
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Ports do compose (não mudar em produção) ────────────────────────────────
WEB_PORT=3000

# ── Backup ─────────────────────────────────────────────────────────────────
# Usado pelo deploy/backup-postgres.sh. Pasta no R2 onde os dumps caem.
BACKUP_R2_REMOTE=r2:naori-backups
BACKUP_RETENTION_DAYS=14
